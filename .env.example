# =============================================================================
# CORRETOR IA — Modelo de variáveis de ambiente
# NUNCA preencha valores reais neste arquivo. Copie para ".env.local" (ou
# ".env" conforme o ambiente) e preencha localmente. ".env*" está no
# .gitignore e não deve ser versionado.
# Este arquivo será revisado e efetivamente utilizado a partir da Fase 1
# (Fundação do Projeto). Nesta Fase 0 ele documenta apenas o desenho
# esperado das integrações.
# =============================================================================

# --- Aplicação -----------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Banco de dados (PostgreSQL via Prisma + Docker Compose) ---------------
# As variáveis POSTGRES_* abaixo também são lidas pelo docker-compose.yml
# para provisionar o Postgres local. Mantenha DATABASE_URL consistente com
# elas. Use "127.0.0.1" em vez de "localhost": no Windows, com Docker
# Desktop, a resolução de "localhost" pode preferir IPv6 e travar a
# conexão, pois o proxy de porta do Docker Desktop escuta em IPv4.
POSTGRES_USER=corretor_ia
POSTGRES_PASSWORD=corretor_ia_dev_only
POSTGRES_DB=corretor_ia
POSTGRES_PORT=5432
DATABASE_URL=postgresql://corretor_ia:corretor_ia_dev_only@127.0.0.1:5432/corretor_ia?schema=public

# --- Autenticação ----------------------------------------------------------
AUTH_SECRET=
AUTH_TRUST_HOST=true
# Duração da sessão em segundos
AUTH_SESSION_MAX_AGE=

# --- Armazenamento de imagens (compatível com S3) ---------------------------
STORAGE_PROVIDER=s3
STORAGE_BUCKET_NAME=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# --- Provedor de IA (abstraído — ver ADR 0004) ------------------------------
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_REQUEST_TIMEOUT_MS=

# --- Limites de uso por plano ------------------------------------------------
AI_MONTHLY_GENERATION_LIMIT=

# --- Observabilidade ---------------------------------------------------------
LOG_LEVEL=info
ERROR_MONITORING_DSN=

# --- Rate limiting -------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_ATTEMPTS=
