// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Trilha de auditoria (RN-094). Não usa relação formal (@relation) com
/// o model "user" gerado pelo Better Auth de propósito: um registro de
/// auditoria deve sobreviver mesmo que a conta referenciada seja
/// removida no futuro, então userId é apenas uma referência solta.

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String
  entityType   String
  entityId     String
  safeMetadata Json?
  ipHash       String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_log")
}

model User {
  id                String    @id
  name              String
  email             String
  emailVerified     Boolean   @default(false)
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  role              String?
  banned            Boolean?  @default(false)
  banReason         String?
  banExpires        DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  sessions          Session[]
  accounts          Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id
  key         String
  count       Int
  lastRequest BigInt

  @@unique([key])
  @@map("rateLimit")
}

/// Perfil profissional do corretor (RN-015 a RN-025). userId não usa
/// @relation formal com "user" pelo mesmo motivo do AuditLog: evita
/// conflito com o model "user", que é gerado/gerenciado pelo CLI do
/// Better Auth (ver ADR-0002) — a posse é sempre validada na camada de
/// serviço a partir da sessão autenticada, nunca por FK.
model BrokerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  professionalName String
  fullName         String
  photoUrl         String?
  logoUrl          String?
  creciNumber      String?
  creciState       String?
  phone            String?
  whatsapp         String?
  commercialEmail  String?
  biography        String?
  city             String?
  state            String?
  businessAddress  String?
  instagramUrl     String?
  facebookUrl      String?
  linkedinUrl      String?
  websiteUrl       String?
  slug             String   @unique
  primaryColor     String?
  secondaryColor   String?
  catalogEnabled   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  properties              Property[]
  generatedAdvertisements GeneratedAdvertisement[]

  @@map("broker_profile")
}

enum PropertyPurpose {
  SALE
  RENT
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  FARM_SMALL
  FARM
  RANCH
  COMMERCIAL_ROOM
  COMMERCIAL_PROPERTY
  WAREHOUSE
  PENTHOUSE
  TOWNHOUSE
  STUDIO
  OTHER
}

/// RN-027.
enum PropertyStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  INACTIVE
}

/// RN-039/RN-040.
enum AddressVisibility {
  HIDDEN_EXACT
  FULL_ADDRESS
}

enum FeatureType {
  POOL
  BARBECUE
  GOURMET_AREA
  BALCONY
  GARDEN
  BACKYARD
  ELEVATOR
  GYM
  PARTY_ROOM
  CONCIERGE
  GATED_COMMUNITY
  AIR_CONDITIONING
  SOLAR_ENERGY
  ACCESSIBILITY
  SEA_VIEW
  STREET_FRONT
  SERVICE_AREA
}

enum MediaType {
  PHOTO
}

/// Imóvel (RN-026 a RN-045). brokerId usa @relation formal com
/// BrokerProfile (ao contrário de User/BrokerProfile, este model é
/// inteiramente nosso, sem conflito com o Better Auth).
model Property {
  id                   String          @id @default(uuid())
  brokerId             String
  broker               BrokerProfile   @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  internalTitle        String
  publicTitle          String?
  referenceCode        String?
  purpose              PropertyPurpose
  propertyType         PropertyType
  status               PropertyStatus  @default(DRAFT)
  price                Decimal?        @db.Decimal(12, 2)
  showPrice            Boolean         @default(true)
  condominiumFee       Decimal?        @db.Decimal(12, 2)
  propertyTax          Decimal?        @db.Decimal(12, 2)
  bedrooms             Int?
  suites               Int?
  bathrooms            Int?
  parkingSpaces        Int?
  totalArea            Decimal?        @db.Decimal(10, 2)
  builtArea            Decimal?        @db.Decimal(10, 2)
  constructionYear     Int?
  furnished            Boolean         @default(false)
  petFriendly          Boolean         @default(false)
  financingAccepted    Boolean         @default(false)
  exchangeAccepted     Boolean         @default(false)
  description          String?
  highlights           String?
  nearbyPlaces         String?
  commercialConditions String?
  internalNotes        String?
  seoTitle             String?
  seoDescription       String?
  slug                 String?
  featured             Boolean         @default(false)
  publishedAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  address                 PropertyAddress?
  features                PropertyFeature[]
  media                   PropertyMedia[]
  generatedAdvertisements GeneratedAdvertisement[]

  @@unique([brokerId, slug])
  @@unique([brokerId, referenceCode])
  @@index([brokerId, status])
  @@index([status, publishedAt])
  @@map("property")
}

model PropertyAddress {
  id             String            @id @default(uuid())
  propertyId     String            @unique
  property       Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zipCode        String?
  state          String?
  city           String?
  neighborhood   String?
  street         String?
  number         String?
  complement     String?
  referencePoint String?
  latitude       Decimal?          @db.Decimal(10, 7)
  longitude      Decimal?          @db.Decimal(10, 7)
  visibilityType AddressVisibility @default(HIDDEN_EXACT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("property_address")
}

model PropertyFeature {
  id          String      @id @default(uuid())
  propertyId  String
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  featureType FeatureType

  @@unique([propertyId, featureType])
  @@map("property_feature")
}

model PropertyMedia {
  id           String    @id @default(uuid())
  propertyId   String
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type         MediaType @default(PHOTO)
  storageKey   String
  publicUrl    String
  thumbnailUrl String?
  altText      String?
  displayOrder Int       @default(0)
  isCover      Boolean   @default(false)
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@index([propertyId, displayOrder])
  @@map("property_media")
}

enum AdvertisementChannel {
  INSTAGRAM
  FACEBOOK
  WHATSAPP
  STORY
  GENERIC
}

enum AdvertisementTone {
  PROFESSIONAL
  ELEGANT
  WELCOMING
  OBJECTIVE
  PERSUASIVE
  HIGH_END
  INVESTMENT
}

enum AdvertisementStatus {
  GENERATED
  EDITED
  FAILED
}

enum AdvertisementSize {
  SHORT
  MEDIUM
  LONG
}

/// Anúncio gerado por IA (RN-061 a RN-074). brokerId e propertyId usam
/// @relation formal — mesmo padrão de Property (este model é
/// inteiramente nosso, sem conflito com o Better Auth).
model GeneratedAdvertisement {
  id               String               @id @default(uuid())
  brokerId         String
  broker           BrokerProfile        @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  propertyId       String
  property         Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel          AdvertisementChannel
  tone             AdvertisementTone
  size             AdvertisementSize
  objective        String
  targetAudience   String?
  highlightAspects String[]             @default([])
  title            String
  content          String
  callToAction     String
  hashtags         String[]             @default([])
  /// Nome do provedor de IA usado (ex.: "anthropic", "fake") — RN-069.
  provider         String
  /// Identificador do modelo usado (ex.: "claude-sonnet-5") — RN-069.
  model            String
  status           AdvertisementStatus  @default(GENERATED)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  /// RN-070: contagem de gerações por corretor num período.
  @@index([brokerId, createdAt])
  @@index([propertyId, createdAt])
  @@map("generated_advertisement")
}
